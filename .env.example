# Copy to .env and adjust as needed.

# PostgreSQL (matches docker-compose.yml service `db`)
DATABASE_URL="postgresql://mnemonic:mnemonic@localhost:5432/mnemonic"

# Better Auth (see https://www.better-auth.com/docs/installation)
# BETTER_AUTH_SECRET= # generate with: bunx --bun @better-auth/cli secret
# BETTER_AUTH_URL="http://localhost:3000" # app base URL; required so SSR/session fetches use an absolute URL

# Google Generative AI (https://ai.google.dev/gemini-api/docs)
GOOGLE_GENERATIVE_AI_API_KEY=

# Exa web search (https://dashboard.exa.ai/api-keys)
EXA_API_KEY=

# RustFS / S3-compatible artifact storage (matches docker-compose.yml service `rustfs`)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="rustfsadmin"
S3_SECRET_ACCESS_KEY="rustfsadmin"
S3_BUCKET="mnemonic-artifacts"
S3_FORCE_PATH_STYLE="true"
