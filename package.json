{
  "name": "mnemonic",
  "private": true,
  "type": "module",
  "imports": {
    "@/*": "./src/*"
  },
  "scripts": {
    "dev": "bunx --bun vite dev --port 3000",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "check": "bun run typecheck && bun run build",
    "lint": "oxlint --fix",
    "format": "oxfmt",
    "fix": "bun run lint && bun run format",
    "db:dev": "docker compose up -d --wait",
    "db:reset": "docker compose down -v",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "PATH=\"./scripts/bin:$PATH\" drizzle-kit studio",
    "mastra:dev": "mastra dev"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.195",
