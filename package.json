{
  "name": "mnemonic",
  "private": true,
  "type": "module",
  "imports": {
    "@/*": "./src/*"
  },
  "scripts": {
    "dev": "bun db:dev && vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --fix",
    "format": "oxfmt",
    "fix": "bun lint && bun format",
    "db:dev": "docker compose up -d --wait",
    "db:reset": "docker compose down -v",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "PATH=\"./scripts/bin:$PATH\" drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@posthog/react": "^1.7.0",
    "@t3-oss/env-core": "^0.13.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^1.0.0-beta.22",
    "drizzle-orm": "^1.0.0-beta.22",
    "lucide-react": "^1.14.0",
    "nitro": "npm:nitro-nightly@latest",
    "posthog-js": "^1.358.1",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.13.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-event-client": "latest",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript/native-preview": "^7.0.0-dev.20260507.1",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "ultracite": "^7.6.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
